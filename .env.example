# Telegram
BOT_TOKEN=1234567890:replace-with-token-from-botfather

# Run mode: polling | webhook
RUN_MODE=polling

# Webhook (used only when RUN_MODE=webhook)
WEBHOOK_BASE_URL=https://bot.example.com
WEBHOOK_SECRET=change-me-to-random-string
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Database
# In docker-compose use hostname "postgres". Use "localhost" if running app outside docker.
DATABASE_URL=postgresql+asyncpg://astrobot:astrobot@postgres:5432/astrobot

# Redis (FSM storage + webhook idempotency dedupe)
REDIS_URL=redis://redis:6379/0

# LLM (DeepSeek via OpenAI-compatible API)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=deepseek-v4-flash
# Optional per-kind overrides — useful if you want a heavier model for natal only
# LLM_MODEL_NATAL=deepseek-v4-pro
# LLM_MODEL_HOROSCOPE=deepseek-v4-flash
# LLM_MODEL_QUESTION=deepseek-v4-flash

# Logging
LOG_LEVEL=INFO

# Grafana (admin login)
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
# Subdomain Caddy serves Grafana on (must have a DNS A-record → server IP).
# e.g. grafana.astrobot.dns.army. Leave unset to keep Grafana off the public web
# (reachable only via SSH tunnel to localhost:3000).
GRAFANA_DOMAIN=

# Admin panel
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-too
ADMIN_SECRET=long-random-string-for-session-cookies

# Bot meta
BOT_USERNAME=astrology_bbot

# Ops chat for error alerts (your personal/admin TG chat id; get from @RawDataBot)
OPS_CHAT_ID=

# Optional welcome animation on first /start: a direct gif/mp4 URL or a Telegram
# file_id. Empty → text-only greeting.
WELCOME_ANIMATION=

# Optional animation for the 48h-after-registration follow-up. URL or file_id.
# Empty → text-only follow-up.
FOLLOWUP_ANIMATION=

# Push schedule (premium morning horoscope, hour of user local tz)
PUSH_HOROSCOPE_HOUR=9

# YooKassa (direct REST API) — get from https://yookassa.ru merchant cabinet
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Where YooKassa returns the user after payment. Empty → derived to https://t.me/<BOT_USERNAME>
YOOKASSA_RETURN_URL=
# Optional CSV of allowed webhook source IPs (extra layer; main check re-fetches the payment)
YOOKASSA_WEBHOOK_IPS=
# Fiscal receipt VAT code (54-ФЗ) — REQUIRED by YooKassa on each receipt item:
# 1 = без НДС (НПД/УСН), 4 = НДС 20% (ОСН). Tax system (СНО) is set in the cabinet.
YOOKASSA_VAT_CODE=1
# Auto-renewing subscriptions (recurring payments). Keep 'false' until YooKassa
# has enabled recurring for your shop — otherwise the monthly plan fails to
# create ("ошибка создания"). With it off the monthly plan is a one-time payment.
RECURRING_ENABLED=false
# Refund policy: refundable only within N days of purchase AND if consumed <= X%
REFUND_WINDOW_DAYS=14
REFUND_MAX_CONSUMED_PCT=25

# LLM pricing for cost tracking (USD per 1M tokens, DeepSeek V4 Flash defaults)
LLM_PRICE_INPUT_USD_PER_M=0.14
LLM_PRICE_OUTPUT_USD_PER_M=0.28
LLM_PRICE_CACHE_HIT_USD_PER_M=0.07
