{$BOT_DOMAIN} {
    encode gzip

    # Grafana under /grafana/ — HTTPS via Caddy, no extra public port needed.
    # Pairs with GF_SERVER_ROOT_URL + GF_SERVER_SERVE_FROM_SUB_PATH in the prod
    # compose override (the prefix is kept, not stripped — Grafana serves it).
    handle /grafana /grafana/* {
        reverse_proxy grafana:3000
    }

    # Everything else → the bot app (webhook, /admin, /metrics, /health).
    handle {
        reverse_proxy app:8000
    }

    log {
        output stderr
        format console
    }
}
