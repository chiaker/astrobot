# Bot (webhook, /admin, /metrics, /health) on the main domain.
{$BOT_DOMAIN} {
	reverse_proxy app:8000
	encode gzip
	log {
		output stderr
		format console
	}
}

# Grafana on its own subdomain (served at root — no sub-path quirks).
# GRAFANA_DOMAIN defaults to grafana.localhost when unset (internal cert, no
# public ACME) so this block never breaks the bot's site.
{$GRAFANA_DOMAIN} {
	reverse_proxy grafana:3000
	encode gzip
}
