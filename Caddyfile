# Bot (webhook, /admin, /metrics, /health) on the main domain.
{$BOT_DOMAIN} {
	# Dynamic upstreams so deploys are zero-downtime: docker-rollout briefly runs
	# two `app` replicas, and Docker's embedded DNS (127.0.0.11) returns an A
	# record per replica. Re-resolving every 2s lets Caddy pick up the new
	# container and drop the old one without a config reload. lb_try_duration +
	# fail_duration retry a request that lands on a container being torn down.
	reverse_proxy {
		dynamic a {
			name app
			port 8000
			refresh 2s
			resolvers 127.0.0.11
		}
		lb_policy round_robin
		lb_try_duration 5s
		fail_duration 10s
	}
	encode gzip
	log {
		output stderr
		format console
	}
}

# MAX bot (webhook, /admin, /metrics, /health) on its own subdomain.
{$MAX_DOMAIN} {
	reverse_proxy {
		dynamic a {
			name app-max
			port 8000
			refresh 2s
			resolvers 127.0.0.11
		}
		lb_policy round_robin
		lb_try_duration 5s
		fail_duration 10s
	}
	encode gzip
	log {
		output stderr
		format console
	}
}

# Grafana on its own subdomain (served at root — no sub-path quirks).
# GRAFANA_DOMAIN defaults to grafana.localhost when unset (internal cert, no
# public ACME) so this block never breaks the bot's site.
{$GRAFANA_DOMAIN} {
	reverse_proxy grafana:3000
	encode gzip
}
