{
  "title": "Ресурсы (сервер и контейнеры)",
  "uid": "resources",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "CPU сервера, %",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "RAM сервера, %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 92 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Load average (1m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": { "defaults": { "decimals": 2 } },
      "targets": [{ "expr": "node_load1", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Свободно на диске /, ГБ",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "min(node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|fuse.*\"}) / 1024 / 1024 / 1024",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU сервера, %",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RAM сервера, использовано (ГБ)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "decgbytes" } },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024 / 1024",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes / 1024 / 1024 / 1024",
          "legendFormat": "total",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU по контейнерам (ядра)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 3 } },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RAM по контейнерам (МБ)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{name!=\"\"}) / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Сеть контейнеров, RX/TX (КБ/с)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "KBs" } },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[5m])) / 1024",
          "legendFormat": "RX {{name}}",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[5m])) / 1024",
          "legendFormat": "TX {{name}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Свободно по дискам (ГБ)",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "decgbytes" } },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|fuse.*\"} / 1024 / 1024 / 1024",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ]
    }
  ]
}
